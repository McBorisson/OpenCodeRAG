reateEmbedder(config), embedBatch()\n  vectorstore/\n    lancedb.ts        — LanceDBStore with memory:// support for tests\n  retriever/\n    retriever.ts      — retrieve(query, embedder, store, options)\n  types/\n    opencode-plugin.d.ts  — local type declaration for @opencode-ai/plugin\n  cli.ts              — commander: index, query, clear, status\n  plugin.ts           — ragPlugin: chat.message hook\n  index.ts            — public API re-exports + plugin default export\n  __tests__/          — mirrors module structure\n```\n```\n\n[/home/christoph/code/OpenCodeRAG/src/__tests__/core/config.test.ts:97-120] (typescript, score: 0.56)\n```typescript\n() => {\n  it(\"has ollama as default embedding provider\", () => {\n    assert.equal(DEFAULT_CONFIG.embedding.provider, \"ollama\");\n  });\n\n  it(\"includes TypeScript extensions\", () => {\n    assert.ok(DEFAULT_CONFIG.indexing.includeExtensions.includes(\".ts\"));\n    assert.ok(DEFAULT_CONFIG.indexing.includeExtensions.includes(\".tsx\"));\n  });\n\n  it(\"excludes node_modules, .git, and .opencode\", () => {\n    assert.ok(DEFAULT_CONFIG.indexing.excludeDirs.includes(\"node_modules\"));\n    assert.ok(DEFAULT_CONFIG.indexing.excludeDirs.includes(\".git\"));\n    assert.ok(DEFAULT_CONFIG.indexing.excludeDirs.includes(\".opencode\"));\n  });\n\n  it(\"has openCode enabled by default\", () => {\n    assert.equal(DEFAULT_CONFIG.openCode.enabled, true);\n  });\n\n  it(\"has topK of 10\", () => {\n    assert.equal(DEFAULT_CONFIG.retrieval.topK, 10);\n  });\n}\n```\n\n[/home/christoph/code/OpenCodeRAG/PLANNING.md:3-17] (markdown, score: 0.56)\n```markdown\n## ✅ Completed (MVP)\n\n- [x] AST-based code chunking (TypeScript, Python, Java, Go, Markdown + fallback)\n- [x] Embedding providers (Ollama + OpenAI, factory-pattern dispatch)\n- [x] Vector storage (LanceDB with `memory://` test mode)\n- [x] Retrieval pipeline (embed → search → score → return)\n- [x] CLI (index, query, clear, status via commander)\n- [x] OpenCode pl